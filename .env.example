GROQ_API_KEY=your_groq_api_key_here

# Optional — only needed for YouTube on cloud hosts (Render, AWS, etc.)
# YouTube blocks datacenter IPs; a residential proxy routes requests through a home IP.
# YOUTUBE_PROXY_URL=http://user:pass@proxy.example.com:8080
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
